{
    "name": "odibi-dev",
    "build": {
        "dockerfile": "../Dockerfile"
    },
    "postCreateCommand": "pip install -e '.[dev,spark,polars,thermodynamics,pandas,azure,sql,postgres,lineage]'",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "charliermarsh.ruff",
                "ms-python.debugpy"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python",
                "python.testing.pytestEnabled": true
            }
        }
    }
}
